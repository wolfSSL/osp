+	serialized = XMALLOC((size_t)size, NULL, DYNAMIC_TYPE_TMP_BUFFER);
+	if (serialized == NULL) {
+		NET_ERR("Failed to allocate session buffer.");
+		goto exit;
+	}
+
+	{
+		unsigned char *p = serialized;
+
+		size = wolfSSL_i2d_SSL_SESSION(session, &p);
+	}
