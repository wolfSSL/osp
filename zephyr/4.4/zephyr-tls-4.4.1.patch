+		context->options.dtls_cid.cid_len = 0;
+		break;
+	case ZSOCK_TLS_DTLS_CID_ENABLED:
+		context->options.dtls_cid.enabled = true;
+		if (context->options.dtls_cid.cid_len == 0) {
+			/* generate random self cid */
