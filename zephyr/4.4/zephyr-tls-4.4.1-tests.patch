@@ -302,6 +382,16 @@ static void client_connect_work_handler(struct k_work *work)
 		     sizeof(struct net_sockaddr_in) : sizeof(struct net_sockaddr_in6));
 }
 
+static void client_connect_work_handler_err(struct k_work *work)
+{
